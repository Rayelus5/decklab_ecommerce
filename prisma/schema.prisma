generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- USUARIOS Y AUTH ---

enum UserRole {
  ADMIN
  CUSTOMER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   @db.Text // Hashed
  role          UserRole  @default(CUSTOMER)
  
  // Datos Cliente
  stripeCustomerId String? @unique
  
  // Lógica PRO
  isPro               Boolean   @default(false)
  proSubscriptionId   String?   // ID de sub en Stripe
  proTierId           String?   // Relación con el nivel
  proAllowanceBalance Decimal   @default(0) @db.Decimal(10, 2) // "Saldo" de volumen de compra disponible
  proSince            DateTime? // Para calcular permanencia mínima
  
  addresses     Address[]
  orders        Order[]
  sessions      Session[]
  accounts      Account[]
  
  proTier       ProTier? @relation(fields: [proTierId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Address {
  id          String  @id @default(cuid())
  userId      String
  label       String? // "Casa", "Oficina"
  line1       String
  line2       String?
  city        String
  postalCode  String
  province    String?
  country     String  @default("ES") // ES (Nacional) o código EU
  phone       String
  
  isDefault   Boolean @default(false)
  
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]
}

// --- CATÁLOGO ---

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  parentId    String?
  
  parent      Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryToCategory")
  products    Product[]
}

model Product {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String   @db.Text
  categoryId  String?
  
  isArchived  Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  
  category    Category? @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
  images      ProductImage[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0) // Para ordenar
  
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id              String  @id @default(cuid())
  productId       String
  sku             String  @unique
  title           String? // Ej: "Rojo / XL"
  
  // Precios
  price           Decimal @db.Decimal(10, 2)
  pricePro        Decimal? @db.Decimal(10, 2)
  
  // Reglas PRO específicas del producto
  proExempt       Boolean @default(false) // Si true, comprarlo a precio PRO NO resta saldo
  
  // Inventario y Envío
  stock           Int     @default(0)
  weight          Int     @default(0) // En GRAMOS. Crucial para envíos
  
  attributes      Json?   // { color: "red", size: "xl" }
  
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
}

// --- REGLAS DE NEGOCIO (PRO & ENVÍOS) ---

// Los 5 niveles (Nivel 1, Nivel 2...)
model ProTier {
  id              String  @id @default(cuid())
  name            String  @unique // "Nivel 1", "Nivel 5"
  priceMonthly    Decimal @db.Decimal(10, 2) // 4.99, 39.99
  monthlyAllowance Decimal @db.Decimal(10, 2) // 50.00, 400.00 (Saldo volumen compra)
  stripePriceId   String  // ID del precio recurrente en Stripe
  
  description     String? @db.Text
  benefits        Json?   // Lista de ventajas para UI
  
  users           User[]
}

enum ShippingRegion {
  NATIONAL // España
  EUROPE   // Resto Europa
}

model ShippingRate {
  id            String         @id @default(cuid())
  name          String         // "Ordinario Nacional <500g"
  type          String         // "ORDINARIO" | "CERTIFICADO"
  region        ShippingRegion
  
  minWeight     Int            // Gramos (0)
  maxWeight     Int            // Gramos (500)
  price         Decimal        @db.Decimal(10, 2)
  
  active        Boolean        @default(true)
}

// --- PEDIDOS ---

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     Int         @unique @default(autoincrement()) // Formato amigable #1001
  userId          String
  
  status          OrderStatus @default(PENDING)
  isPaid          Boolean     @default(false)
  
  // Totales
  total           Decimal     @db.Decimal(10, 2)
  subtotal        Decimal     @db.Decimal(10, 2)
  taxTotal        Decimal     @db.Decimal(10, 2)
  shippingCost    Decimal     @db.Decimal(10, 2)
  discountTotal   Decimal     @default(0) @db.Decimal(10, 2)
  
  // Datos snapshot (por si cambian las tarifas luego)
  shippingType    String      // "ORDINARIO"
  shippingRegion  String      // "NATIONAL"
  
  // Pago
  stripePaymentIntentId String? @unique
  
  // Facturación
  invoiceUrl      String?     // PDF generado
  
  // Relaciones
  user            User        @relation(fields: [userId], references: [id])
  address         Address?    @relation(fields: [addressId], references: [id])
  addressId       String?
  
  items           OrderItem[]
  shipment        Shipment?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id              String         @id @default(cuid())
  orderId         String
  variantId       String
  
  quantity        Int
  pricePaid       Decimal        @db.Decimal(10, 2) // El precio final unitario
  
  // Flag crítico para saber si consumió saldo PRO
  wasProPrice     Boolean        @default(false) 
  
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant         ProductVariant @relation(fields: [variantId], references: [id])
}

model Shipment {
  id              String   @id @default(cuid())
  orderId         String   @unique
  
  carrier         String   @default("CORREOS")
  trackingNumber  String?
  labelUrl        String?  // Si subimos imagen de la etiqueta
  
  shippedAt       DateTime?
  deliveredAt     DateTime?
  
  order           Order    @relation(fields: [orderId], references: [id])
}